# FiLo 서버 필수 환경 변수 (복사 후 .env 로 저장하고 값 채우기)

# 서버 포트 (없으면 5000 사용)
PORT=5000

# MongoDB 연결 문자열 (필수)
# 예: mongodb://localhost:27017/filo 또는 Atlas URI
MONGO_URI=mongodb://localhost:27017/filo

# 세션 암호 (필수, 아무 랜덤 문자열)
SESSION_SECRET=your-session-secret-change-this

# Google 로그인 (선택)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Redis (선택, 없으면 메모리 캐시 사용)
# REDIS_HOST=localhost
# REDIS_PORT=6379
